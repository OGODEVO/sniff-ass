# Polygon Wallet
PRIVATE_KEY=your_polygon_wallet_private_key_here
POLYMARKET_PROXY_ADDRESS=your_polymarket_proxy_address_here

# Bot Config
DRY_RUN=true
BANKROLL=1000.0

# Polygon RPC (for Chainlink on-chain price feed)
POLYGON_RPC_URL=https://polygon-rpc.com

# Binance WebSocket Base URL (Optional)
# If running on a US VPS, uncomment and use the US endpoint to avoid HTTP 451 geo-block errors:
# BINANCE_WS_BASE=wss://stream.binance.us:9443/stream?streams=
