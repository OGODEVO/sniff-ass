# Polygon Wallet
PRIVATE_KEY=your_polygon_wallet_private_key_here
POLYMARKET_PROXY_ADDRESS=your_polymarket_proxy_address_here

# Bot Config
DRY_RUN=true
BANKROLL=1000.0
PAPER_USE_GAMMA_FALLBACK=false
ENABLED_TIMEFRAMES_MIN=15
ENABLE_EARLY_ENTRY=false
REQUIRE_BID_FOR_ENTRY=true
MAX_ENTRY_SPREAD=0.04
TAKER_FEE_BPS=20
EXECUTION_SLIPPAGE_BPS=10
LATENCY_BUFFER_MIN=0.005
LATENCY_SPREAD_MULT=0.5
MIN_NET_EDGE=0.015
MIN_EDGE=0.045
MIN_TRUE_PROB=0.52
MAX_POSITION_PCT=0.10
KELLY_FRACTION_EARLY=0.30
KELLY_FRACTION_LATE=0.22
MAX_SIMULTANEOUS=2
DAILY_LOSS_LIMIT_PCT=0.08
MAX_DRAWDOWN_PCT=0.15
MIN_TIME_REMAINING=1.0
LATE_WINDOW_START=6.0

# Polygon RPC (for Chainlink on-chain price feed)
POLYGON_RPC_URL=https://polygon-rpc.com

# Binance WebSocket Base URL (Optional)
# If running on a US VPS, uncomment and use the US endpoint to avoid HTTP 451 geo-block errors:
# BINANCE_WS_BASE=wss://stream.binance.us:9443/stream?streams=
